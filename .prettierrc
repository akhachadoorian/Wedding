{
    "tabWidth": 4,
    "printWidth": 9999,
    "bracketSpacing": true,
    "plugins": ["@trivago/prettier-plugin-sort-imports"],
    "importOrder": [
        "^react",
        "^react-router",
        "<THIRD_PARTY_MODULES>",
        "^./context/(.*)$",
        "^./components/(.*)$",
        "^./pages/(.*)$",
        "^./styles/(.*)$",
        "^[./].*\\.css$",
        "^[./].*\\.scss$"
    ],
    "importOrderSeparation": true,
    "importOrderSortSpecifiersWithinImportDeclarations": true
}