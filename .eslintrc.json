{
    "extends": ["react-app"],
    "plugins": ["import"],
    "rules": {
        "import/order": ["warn", {
            "groups": [
                "builtin",
                "external",
                "internal",
                ["parent", "sibling", "index"]
            ],
            "pathGroups": [
                {
                    "pattern": "react",
                    "group": "external",
                    "position": "before"
                },
                {
                    "pattern": "./**/*.scss",
                    "group": "sibling",
                    "position": "after"
                }
            ],
            "newlines-between": "always",
            "alphabetize": {
                "order": "asc",
                "caseInsensitive": true
            }
        }]
    }
}